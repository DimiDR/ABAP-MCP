# ============================================================
# ABAP MCP Server v2 — Konfiguration
# ============================================================

# SAP-Systemverbindung (alle drei Pflichtfelder)
SAP_URL=https://ihr-sap-system:44300
SAP_USER=DEVELOPER
SAP_PASSWORD=IhrPasswort
SAP_CLIENT=100
SAP_LANGUAGE=DE

# ── Schreibschutz ──────────────────────────────────────────
# ALLOW_WRITE=true  → Schreib-Tools aktiviert (nur DEV-System!)
# ALLOW_WRITE=false → Read-only Modus (sicher für alle Systeme)
ALLOW_WRITE=false

# ALLOW_DELETE=true → delete_abap_object aktiviert
# Nur wirksam wenn ALLOW_WRITE=true
ALLOW_DELETE=false

# ALLOW_EXECUTE=true → execute_abap_snippet aktiviert (temporären ABAP-Code ausführen)
# Erfordert zusätzlich ALLOW_WRITE=true
ALLOW_EXECUTE=false

# ── Paket-Sperrung ─────────────────────────────────────────
# Kommaliste gesperrter Paket-Präfixe
# KI kann NICHT in diese Pakete schreiben
BLOCKED_PACKAGES=SAP,SHD,SMOD

# ── Transporte ─────────────────────────────────────────────
# Standard-Transport wenn kein Transport angegeben
# Leer lassen für lokale Objekte ($TMP)
DEFAULT_TRANSPORT=

# ── Qualitätssicherung ─────────────────────────────────────
# Syntaxcheck vor Aktivierung erzwingen (empfohlen: true)
SYNTAX_CHECK_BEFORE_ACTIVATE=true

# ── SSL/TLS ───────────────────────────────────────────────
# Selbstsignierte Zertifikate erlauben (true/false)
# SAP_ALLOW_UNAUTHORIZED=true

# ── Diagnose ───────────────────────────────────────────────
# Maximale Anzahl Short Dumps bei get_short_dumps
MAX_DUMPS=20

# ── Tool Discovery ────────────────────────────────────────
# DEFER_TOOLS=true  → Nur Kern-Tools initial laden, Rest on-demand via find_tools (spart ~75% Tokens)
# DEFER_TOOLS=false → Alle Tools sofort laden (Legacy-Modus)
DEFER_TOOLS=true

# ── Dokumentation ─────────────────────────────────────────
# ABAP-Version für help.sap.com Dokumentation (z.B. "latest", "758", "754")
SAP_ABAP_VERSION=latest

# ── Web Search (Tavily) ──────────────────────────────────
# Ermöglicht search_sap_web Tool: Suche über SAP Help, Community & Notes
# Setup: https://tavily.com/ → Sign up → API Key kopieren
# Free Tier: 1000 Searches/Monat
TAVILY_API_KEY=
